# Optional API key for premium live weather provider.
# If empty, the server automatically falls back to Open-Meteo and synthetic data.
OPENWEATHER_API_KEY=

# SQLite database file path.
SQLITE_DB_PATH=./flood_data.db

# Cache lifetime for live weather snapshots in minutes.
LIVE_WEATHER_MAX_AGE_MINUTES=20

# Model metadata shown in admin metrics.
MODEL_VERSION=heuristic-v2

# Server port
PORT=3000
